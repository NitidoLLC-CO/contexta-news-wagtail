DJANGO_SETTINGS_MODULE=contexta_news.settings.production
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql://user:password@host:5432/database
ALLOWED_HOSTS=.up.railway.app,healthcheck.railway.app
CSRF_TRUSTED_ORIGINS=https://*.up.railway.app
WAGTAIL_SITE_NAME=CONTEXTRA News
WAGTAILADMIN_BASE_URL=https://replace-with-your-railway-domain.up.railway.app
MEDIA_ROOT=/app/media
MEDIA_URL=/media/
SERVE_MEDIA_WITH_DJANGO=true

# Optional: set these once to create the first production admin user on deploy.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=replace-with-a-strong-password
